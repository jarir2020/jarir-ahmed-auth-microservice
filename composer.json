{
    "name": "jarir-ahmed/auth-microservice",
    "description": "Standalone auth microservice package — Registration, Login, 2FA, Password Reset & more.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.0",
        "ext-hash": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-mbstring": "*",
        "ext-sodium": "*",
        "psr/http-message": "^2.0",
        "psr/container": "^2.0",
        "psr/event-dispatcher": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "JarirAhmed\\AuthMicroservice\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JarirAhmed\\AuthMicroservice\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JarirAhmed\\AuthMicroservice\\Bridge\\Laravel\\AuthMicroserviceServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "audit": {
            "abandoned": "ignore",
            "block-insecure": false
        }
    }
}
